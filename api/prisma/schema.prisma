// BatchFit API schema.
// Accounts are Phase 1 (client–server, login required — see roadmap.md). This models
// the User (auth + profile + the five daily targets). The batch-cooking differentiator
// (Recipe = template, Batch = one cook with snapshotted amounts + portion inventory) is
// modelled below. Diary, workouts and weight entries arrive in later phases; ownership
// (scoping foods/recipes/batches to a user) is added in F3-1 / F5-1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// An account plus the profile and daily targets that onboarding produces.
/// Profile/target fields are nullable until onboarding completes (`onboardingComplete`).
/// Weight and height are stored canonically in metric (kg / cm) regardless of the
/// user's chosen display `units`. SQLite has no enums, so choice fields are strings
/// validated at the app layer:
///   sex           — "male" | "female"
///   activityLevel — "sedentary" | "light" | "moderate" | "active" | "very_active"
///   goal          — "lose" | "maintain" | "build"
///   units         — "metric" | "imperial"
model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String

  // Profile (set during onboarding).
  sex             String?
  birthDate       DateTime?
  heightCm        Float?
  activityLevel   String?
  goal            String?
  goalRateKgPerWk Float?
  currentWeightKg Float?
  goalWeightKg    Float?
  units           String  @default("metric")

  // The five daily targets.
  targetKcal    Float?
  targetProtein Float?
  targetFat     Float?
  targetCarbs   Float?
  targetFibre   Float?

  onboardingComplete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A reference food with macros per 100g. The five tracked nutrients throughout
/// BatchFit are: calories, protein, fat, carbs, fibre.
model Food {
  id       String @id @default(cuid())
  name     String
  brand    String?

  // Macros per 100g.
  kcal     Float
  protein  Float
  fat      Float
  carbs    Float
  fibre    Float

  recipeIngredients RecipeIngredient[]
  batchIngredients  BatchIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A reusable template: an ingredient list + a default portion count.
/// Cooking a recipe produces a Batch (which snapshots the actual amounts used).
model Recipe {
  id              String @id @default(cuid())
  name            String
  defaultPortions Int    @default(1)

  ingredients RecipeIngredient[]
  batches     Batch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String
  food     Food   @relation(fields: [foodId], references: [id])
  foodId   String
  grams    Float

  @@index([recipeId])
}

/// One actual cook. Amounts are snapshotted here (real cooking varies cook-to-cook),
/// so editing the source recipe never rewrites a batch. `portionsRemaining` is the
/// live inventory count and is decremented when a portion is eaten.
model Batch {
  id                String  @id @default(cuid())
  name              String
  recipe            Recipe? @relation(fields: [recipeId], references: [id])
  recipeId          String?
  portionsTotal     Int
  portionsRemaining Int
  cookedAt          DateTime @default(now())

  ingredients BatchIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipeId])
}

model BatchIngredient {
  id      String @id @default(cuid())
  batch   Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId String
  food    Food   @relation(fields: [foodId], references: [id])
  foodId  String
  grams   Float

  @@index([batchId])
}
